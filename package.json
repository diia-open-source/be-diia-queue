{
    "name": "@diia-inhouse/diia-queue",
    "version": "13.2.12",
    "description": "Package provide queue functionality",
    "main": "dist/index.js",
    "types": "dist/types/index.d.ts",
    "repository": "https://github.com/diia-open-source/be-diia-queue",
    "author": "Diia",
    "license": "SEE LICENSE IN LICENSE.md",
    "engines": {
        "node": ">=22"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "rimraf dist/ && tsc",
        "build-watch": "tsc --watch",
        "lint": "eslint . && prettier --check .",
        "lint-fix": "eslint . --fix && prettier --write .",
        "lint:lockfile": "lockfile-lint --path package-lock.json --allowed-hosts registry.npmjs.org --validate-https",
        "format": "prettier --write \"src/**/*.ts\"",
        "prepare": "npm run build",
        "semantic-release": "semantic-release",
        "test": "vitest run",
        "test:watch": "vitest watch",
        "find-circulars": "madge --circular --extensions ts ./"
    },
    "dependencies": {
        "@types/amqplib": "0.10.8",
        "amqplib": "0.10.9",
        "lodash": "4.18.1",
        "p-timeout": "4.1.0"
    },
    "peerDependencies": {
        "@diia-inhouse/diia-logger": ">=3.1.0",
        "@diia-inhouse/diia-metrics": ">=5.0.0",
        "@diia-inhouse/env": ">=2.0.0",
        "@diia-inhouse/errors": ">=1.4.0",
        "@diia-inhouse/types": ">=6.30.0",
        "@diia-inhouse/utils": ">=2.21.0",
        "@diia-inhouse/validators": ">=1.5.0",
        "@opentelemetry/api": ">=1.7.0"
    },
    "devDependencies": {
        "@diia-inhouse/configs": "6.1.1",
        "@diia-inhouse/diia-logger": "3.20.6",
        "@diia-inhouse/diia-metrics": "6.5.29",
        "@diia-inhouse/errors": "1.18.19",
        "@diia-inhouse/eslint-config": "8.8.0",
        "@diia-inhouse/eslint-plugin": "1.9.5",
        "@diia-inhouse/test": "7.3.18",
        "@diia-inhouse/types": "12.0.1",
        "@diia-inhouse/utils": "5.3.23",
        "@diia-inhouse/validators": "1.28.30",
        "@opentelemetry/api": "1.9.0",
        "@types/lodash": "4.17.24",
        "@types/node": "24.11.0",
        "@vitest/coverage-v8": "4.0.18",
        "@vitest/ui": "4.0.18",
        "lockfile-lint": "4.14.1",
        "madge": "8.0.0",
        "prettier": "3.8.1",
        "rimraf": "6.1.3",
        "type-fest": "4.41.0",
        "vite-tsconfig-paths": "6.1.1",
        "vitest": "4.0.18",
        "vitest-mock-extended": "3.1.0"
    },
    "release": {
        "extends": "@diia-inhouse/configs/dist/semantic-release/package"
    },
    "commitlint": {
        "extends": "@diia-inhouse/configs/dist/commitlint"
    },
    "eslintConfig": {
        "extends": "@diia-inhouse/eslint-config",
        "overrides": [
            {
                "files": [
                    "*.ts"
                ],
                "parserOptions": {
                    "project": [
                        "./tsconfig.json",
                        "./tests/tsconfig.json"
                    ]
                }
            }
        ]
    },
    "prettier": "@diia-inhouse/eslint-config/prettier",
    "madge": {
        "tsConfig": "./tsconfig.json"
    }
}
