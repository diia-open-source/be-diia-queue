{
    "extends": "../tsconfig.json",
    "compilerOptions": {
        "baseUrl": "../",
        "paths": {
            "@services/*": ["src/services/*"],
            "@interfaces/*": ["src/interfaces/*"],
            "@src/*": ["src/*"],
            "@mocks/*": ["tests/mocks/*"],
            "@tests/*": ["tests/*"]
        },
        "types": ["vitest/globals"],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "isolatedModules": true,
        "noEmit": true,
        "strict": false
    },
    "include": ["./**/*", "../vitest.config.mts"]
}
